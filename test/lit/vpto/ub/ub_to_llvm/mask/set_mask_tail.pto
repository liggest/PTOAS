// pto.ub.set_mask with partial mask (hi=0, lo=16) -> two MOVEMASK calls.
// Verifies: distinct mask values reach correct call, index ordering 0->1.
// RUN: ptoas --pto-arch=a3 --pto-backend=vpto %s -o %t --mlir-print-ir-after=convert-func-to-llvm 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a3", pto.kernel_kind = #pto.kernel_kind<vector>} {
  // CHECK-LABEL: llvm.func @set_mask_tail_mix_aiv(
  func.func @set_mask_tail() attributes {pto.aicore} {
    %c16 = arith.constant 16 : i64
    %c0 = arith.constant 0 : i64
    // CHECK: %[[LO:.*]] = llvm.mlir.constant(16 : i64) : i64
    // CHECK: llvm.call @llvm.hivm.MOVEMASK({{%.*}}, {{%.*}}) : (i64, i64) -> ()
    // CHECK: llvm.call @llvm.hivm.MOVEMASK({{%.*}}, %[[LO]]) : (i64, i64) -> ()
    // CHECK-NOT: pto.ub.
    pto.ub.set_mask %c0, %c16 : i64, i64
    return
  }
}
