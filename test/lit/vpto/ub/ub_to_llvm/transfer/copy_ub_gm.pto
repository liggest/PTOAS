// A3: copy_ubuf_to_gm -> llvm.hivm.MOV.UB.TO.OUT.v220.1 (3-arg call).
// RUN: ptoas --pto-arch=a3 --pto-backend=vpto %s -o %t --mlir-print-ir-after=convert-func-to-llvm 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a3", pto.kernel_kind = #pto.kernel_kind<vector>} {
  // CHECK-LABEL: llvm.func @copy_ub_gm_a3_f32_mix_aiv(
  // CHECK-SAME: %[[SRC:[^:]+]]: !llvm.ptr<6>, %[[DST:[^:]+]]: !llvm.ptr<1>
  func.func @copy_ub_gm_a3_f32(%src: !pto.ptr<f32, ub>, %dst: !pto.ptr<f32, gm>) attributes {pto.aicore} {
    %c0 = arith.constant 0 : i64
    %c1 = arith.constant 1 : i64
    // CHECK: llvm.call @llvm.hivm.MOV.UB.TO.OUT.v220.1(%[[DST]], %[[SRC]], {{%.*}}) : (!llvm.ptr<1>, !llvm.ptr<6>, i64) -> ()
    // CHECK-NOT: ALIGN
    // CHECK-NOT: .DV
    pto.copy_ubuf_to_gm %src, %dst, %c0, %c1, %c1, %c0, %c1, %c1
      : !pto.ptr<f32, ub>, !pto.ptr<f32, gm>, i64, i64, i64, i64, i64, i64
    return
  }
}
