// pto.ub.vdiv -> llvm.hivm.VDIV.f32.
// RUN: ptoas --pto-arch=a3 --pto-backend=vpto %s -o %t --mlir-print-ir-after=convert-func-to-llvm 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a3", pto.kernel_kind = #pto.kernel_kind<vector>} {
  // CHECK-LABEL: llvm.func @vdiv_llvm_mix_aiv(
  func.func @vdiv_llvm() attributes {pto.aicore} {
    %c0 = arith.constant 0 : i64
    %c1 = arith.constant 1 : i64
    %c8 = arith.constant 8 : i64
    // CHECK: %[[PTR:.*]] = {{.*}} !llvm.ptr<6>
    %ptr = pto.castptr %c0 : i64 -> !pto.ptr<f32, ub>
    // SIMD flag = 1<<56; 8-bit field mask = 255
    // CHECK: llvm.mlir.constant(72057594037927936 : i64) : i64
    // CHECK: llvm.mlir.constant(255 : i64) : i64
    // CHECK: llvm.call @llvm.hivm.VDIV.f32(%[[PTR]], %[[PTR]], %[[PTR]], %[[CFG:.*]]) : (!llvm.ptr<6>, !llvm.ptr<6>, !llvm.ptr<6>, i64) -> ()
    // CHECK-NOT: pto.ub.
    pto.ub.vdiv %ptr, %ptr, %ptr, %c1, %c1, %c1, %c1, %c8, %c8, %c0 :
      !pto.ptr<f32, ub>, !pto.ptr<f32, ub>, !pto.ptr<f32, ub>,
      i64, i64, i64, i64, i64, i64, i64
    return
  }
}
