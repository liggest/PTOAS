// RUN: split-file %s %t
// RUN: not ptoas --pto-arch=a5 --emit-pto-ir %t/result.pto -o - 2>&1 | FileCheck %s --check-prefix=RESULT
// RUN: not ptoas --pto-arch=a5 --emit-pto-ir %t/record_event.pto -o - 2>&1 | FileCheck %s --check-prefix=RECORD-EVENT
// RUN: not ptoas --pto-arch=a5 --emit-pto-ir %t/dynamic_flag.pto -o - 2>&1 | FileCheck %s --check-prefix=DYNAMIC-FLAG
// RUN: not ptoas --pto-arch=a5 --emit-pto-ir %t/simt_metadata.pto -o - 2>&1 | FileCheck %s --check-prefix=SIMT-METADATA

// RESULT: error: {{.*}}tileop helpers must not return values; write results through mutable Tile parameters
// RECORD-EVENT: error: {{.*}}tileop helpers must not contain pipe synchronization
// DYNAMIC-FLAG: error: {{.*}}tileop helpers must not contain pipe synchronization
// SIMT-METADATA: error: {{.*}}tileop helpers must launch a @pto.simt helper instead of containing SIMT operations directly

//--- result.pto
module attributes {pto.target_arch = "a5"} {
  func.func private @result() -> i32 attributes {pto.tileop.helper} {
    %mask = pto.pset_b32 "PAT_ALL" : !pto.mask<b32>
    %one = arith.constant 1 : i32
    return %one : i32
  }
}

//--- record_event.pto
module attributes {pto.target_arch = "a5"} {
  func.func private @record_event() attributes {pto.tileop.helper} {
    pto.record_event [#pto.pipe_event_type<TLOAD>, #pto.pipe_event_type<TVEC>, #pto.event<EVENT_ID0>]
    return
  }
}

//--- dynamic_flag.pto
module attributes {pto.target_arch = "a5"} {
  func.func private @dynamic_flag(%event_id: index) attributes {pto.tileop.helper} {
    pto.set_flag_dyn [#pto.pipe<PIPE_MTE2>, #pto.pipe<PIPE_V>, %event_id]
    return
  }
}

//--- simt_metadata.pto
module attributes {pto.target_arch = "a5"} {
  func.func private @simt_metadata() attributes {pto.tileop.helper} {
    %one = arith.constant 1 : i32
    pto.store_vfsimt_info %one, %one, %one : i32, i32, i32
    return
  }
}
