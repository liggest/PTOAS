// RUN: ptoas --pto-arch=a5 %s -o - 2>&1 | FileCheck %s --check-prefix=A5

module {
  func.func @cube_kernel() attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %c0_i32 = arith.constant 0 : i32
    %scale0 = arith.constant 1.000000e+00 : f32
    %scale1 = arith.constant 2.000000e+00 : f32

    %c2v_import0 = pto.import_reserved_buffer {
      name = "c2v_fifo_0",
      peer_func = @vector_kernel
    } -> i32
    %c2v_import1 = pto.import_reserved_buffer {
      name = "c2v_fifo_1",
      peer_func = @vector_kernel
    } -> i32

    pto.aic_initialize_pipe {
      id = 0,
      dir_mask = 1,
      slot_size = 512,
      nosplit = true,
      acc_push_epilogue =
          #pto.acc_push_epilogue<layout = nz2nd, quant = deqf16_scalar, relu = normal_relu>
    }
      (c2v_consumer_buf = %c2v_import0 : i32,
       v2c_consumer_buf = %c0_i32 : i32)
    pto.aic_initialize_pipe {
      id = 1,
      dir_mask = 1,
      slot_size = 512,
      nosplit = true,
      acc_push_epilogue =
          #pto.acc_push_epilogue<layout = nz2nd, quant = qf322bf16_pre_scalar, relu = no_relu>
    }
      (c2v_consumer_buf = %c2v_import1 : i32,
       v2c_consumer_buf = %c0_i32 : i32)

    %acc_i32_0 = pto.alloc_tile : !pto.tile_buf<loc=acc, dtype=i32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>
    %acc_f32 = pto.alloc_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>
    %acc_i32_1 = pto.alloc_tile : !pto.tile_buf<loc=acc, dtype=i32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>

    pto.set_quant_scalar(%scale0 : f32) {id = 0}
    pto.tpush_to_aiv(%acc_i32_0 : !pto.tile_buf<loc=acc, dtype=i32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>) {id = 0, split = 0}

    pto.set_quant_scalar(%scale1 : f32) {id = 1}
    pto.tpush_to_aiv(%acc_f32 : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>) {id = 1, split = 0}

    pto.tpush_to_aiv(%acc_i32_1 : !pto.tile_buf<loc=acc, dtype=i32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>) {id = 0, split = 0}
    return
  }

  func.func @vector_kernel() attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c0_i32 = arith.constant 0 : i32

    %c2v_local0 = pto.reserve_buffer {
      name = "c2v_fifo_0",
      size = 4096,
      location = #pto.address_space<vec>,
      auto = true
    } -> i32
    %c2v_local1 = pto.reserve_buffer {
      name = "c2v_fifo_1",
      size = 4096,
      location = #pto.address_space<vec>,
      auto = true
    } -> i32

    pto.aiv_initialize_pipe {
      id = 0,
      dir_mask = 1,
      slot_size = 512,
      nosplit = true,
      acc_push_epilogue =
          #pto.acc_push_epilogue<layout = nz2nd, quant = deqf16_scalar, relu = normal_relu>
    }
      (c2v_consumer_buf = %c2v_local0 : i32,
       v2c_consumer_buf = %c0_i32 : i32)
    pto.aiv_initialize_pipe {
      id = 1,
      dir_mask = 1,
      slot_size = 512,
      nosplit = true,
      acc_push_epilogue =
          #pto.acc_push_epilogue<layout = nz2nd, quant = qf322bf16_pre_scalar, relu = no_relu>
    }
      (c2v_consumer_buf = %c2v_local1 : i32,
       v2c_consumer_buf = %c0_i32 : i32)

    %recv0 = pto.tpop_from_aic {id = 0, split = 0}
      -> !pto.tile_buf<loc=vec, dtype=f16, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %recv1 = pto.tpop_from_aic {id = 1, split = 0}
      -> !pto.tile_buf<loc=vec, dtype=bf16, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tfree_from_aic {id = 0, split = 0}
    pto.tfree_from_aic {id = 1, split = 0}
    return
  }
}

// A5-LABEL: AICORE void cube_kernel(
// A5: using Pipe0FixpipeConfig = FixpipeParams<LayoutMode_t::NZ2ND, QuantMode_t::DEQF16, ReluPreMode::NormalRelu>;
// A5: using Pipe1FixpipeConfig = FixpipeParams<LayoutMode_t::NZ2ND, QuantMode_t::QF322BF16_PRE, ReluPreMode::NoRelu>;
// A5: SET_QUANT_SCALAR<half>(
// A5-NEXT: TPUSH<{{.*}}, Pipe0FixpipeConfig>(
// A5: SET_QUANT_SCALAR<bfloat16_t>(
// A5-NEXT: TPUSH<{{.*}}, Pipe1FixpipeConfig>(
// A5: SET_QUANT_SCALAR<half>(
// A5-NEXT: TPUSH<{{.*}}, Pipe0FixpipeConfig>(
