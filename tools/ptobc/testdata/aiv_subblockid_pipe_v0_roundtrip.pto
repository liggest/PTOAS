module {
  func.func @cube_kernel(%gm_slot_buffer: !pto.ptr<f32>)
      attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %v2c_local = pto.reserve_buffer {
      name = "v2c_fifo_subblock",
      size = 4096,
      location = #pto.address_space<mat>,
      auto = true
    } -> i32
    %c2v_import = pto.import_reserved_buffer {
      name = "c2v_fifo_subblock",
      peer_func = @vector_kernel
    } -> i32
    pto.aic_initialize_pipe {id = 0, dir_mask = 3, slot_size = 1024}
      (gm_slot_buffer = %gm_slot_buffer : !pto.ptr<f32>,
       c2v_consumer_buf = %c2v_import : i32,
       v2c_consumer_buf = %v2c_local : i32)

    %acc_tile = pto.alloc_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>
    pto.tpush_to_aiv(%acc_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>) {id = 0, split = 1}

    %mat_tile = pto.tpop_from_aiv {id = 0, split = 1}
      -> !pto.tile_buf<loc=mat, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    pto.tfree_from_aiv {id = 0, split = 1}
    return
  }

  func.func @vector_kernel(%gm_slot_buffer: !pto.ptr<f32>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %c2v_local = pto.reserve_buffer {
      name = "c2v_fifo_subblock",
      size = 4096,
      location = #pto.address_space<vec>,
      auto = true
    } -> i32
    %v2c_import = pto.import_reserved_buffer {
      name = "v2c_fifo_subblock",
      peer_func = @cube_kernel
    } -> i32
    pto.aiv_initialize_pipe {id = 0, dir_mask = 3, slot_size = 1024}
      (gm_slot_buffer = %gm_slot_buffer : !pto.ptr<f32>,
       c2v_consumer_buf = %c2v_local : i32,
       v2c_consumer_buf = %v2c_import : i32)

    %aiv_subblockid = pto.get_subblock_idx
    %vec_tile = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tpush_to_aic(%vec_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>) {split = 1} aiv_subblockid(%aiv_subblockid)

    %recv_tile = pto.tpop_from_aic {split = 1} aiv_subblockid(%aiv_subblockid)
      -> !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tfree_from_aic {id = 0, split = 1}
    return
  }

  func.func @internal_aiv_subblockid(%gm_addr: !pto.ptr<f32>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %local_addr = pto.reserve_buffer {
      name = "internal_subblock_local",
      size = 4096,
      location = #pto.address_space<vec>,
      auto = true
    } -> i32
    %peer_local_addr = pto.reserve_buffer {
      name = "internal_subblock_peer",
      size = 4096,
      location = #pto.address_space<vec>,
      auto = true
    } -> i32
    %pipe = pto.initialize_l2g2l_pipe {
      dir_mask = 3,
      slot_size = 1024,
      slot_num = 4,
      local_slot_num = 2,
      flag_base = 6,
      nosplit = false
    }(%gm_addr : !pto.ptr<f32>, %local_addr : i32, %peer_local_addr : i32) -> !pto.pipe

    %aiv_subblockid = pto.get_subblock_idx
    %src = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tpush(%src, %pipe : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.pipe) {split = 1} aiv_subblockid(%aiv_subblockid)
    %dst = pto.declare_tile -> !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tpop(%dst, %pipe : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.pipe) {split = 1} aiv_subblockid(%aiv_subblockid)
    pto.tfree(%pipe : !pto.pipe) {split = 1}
    return
  }
}
